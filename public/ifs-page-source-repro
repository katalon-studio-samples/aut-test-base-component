<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IFS Page Source Repro</title>
    <script
      defer
      async
      client-code="KA-65405-01"
      src="https://static.qa.katalon.com/libs/traffic-agent/v1/traffic-agent.min.js"
    ></script>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f5f8;
        --panel: #ffffff;
        --border: #d9dbe3;
        --text: #1f2937;
        --muted: #6b7280;
        --hover: #eef5ff;
        --accent: #5f2eea;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family:
          "Segoe UI",
          "Helvetica Neue",
          Arial,
          sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      .layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        min-height: 100vh;
      }

      .sidebar {
        background: var(--panel);
        border-right: 1px solid var(--border);
        padding: 20px 16px;
      }

      .sidebar h1 {
        margin: 0 0 14px;
        font-size: 18px;
      }

      .search {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
      }

      .results {
        margin-top: 18px;
      }

      .result {
        margin-bottom: 10px;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--panel);
        overflow: hidden;
      }

      .result a {
        display: block;
        padding: 12px 14px;
        color: inherit;
        text-decoration: none;
      }

      .result a:hover,
      .result a:focus-visible {
        background: var(--hover);
        outline: none;
      }

      .label {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .subtitle {
        color: var(--muted);
        font-size: 12px;
        line-height: 1.35;
        pointer-events: none;
      }

      .title {
        color: var(--text);
        font-size: 14px;
        font-weight: 600;
        line-height: 1.35;
        pointer-events: none;
      }

      .main {
        padding: 28px;
      }

      .hero {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        max-width: 900px;
      }

      .hero h2 {
        margin: 0 0 10px;
        font-size: 26px;
      }

      .hero p {
        margin: 0 0 10px;
        color: var(--muted);
        line-height: 1.6;
      }

      .badge {
        display: inline-block;
        margin-bottom: 12px;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f1ebff;
        color: var(--accent);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .console {
        margin-top: 18px;
        padding: 16px;
        border-radius: 12px;
        background: #111827;
        color: #e5e7eb;
        font-family:
          ui-monospace,
          SFMono-Regular,
          Menlo,
          Consolas,
          monospace;
        white-space: pre-wrap;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <h1>Navigator menu</h1>
        <input class="search" value="account - crm" readonly />

        <div class="results">
          <div class="result">
            <a
              data-poc="ifs-account-crm-link"
              href="#account-crm"
            >
              <div class="holder">
                <div class="label">
                  <span class="subtitle"
                    >Relationship Management / Customer Relationship
                    Management / Account</span
                  >
                  <span class="title">Account - CRM</span>
                </div>
              </div>
            </a>
          </div>

          <div class="result">
            <a
              data-poc="ifs-accounts-crm-link"
              href="#accounts-crm"
            >
              <div class="holder">
                <div class="label">
                  <span class="subtitle"
                    >Relationship Management / Customer Relationship
                    Management / Account</span
                  >
                  <span class="title">Accounts - CRM</span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </aside>

      <main class="main">
        <section class="hero">
          <div class="badge">Page Source Repro</div>
          <h2>IFS-like nested text reproduction</h2>
          <p>
            This standalone HTML mirrors the structure from
            <code>1 - Page Source.txt</code> more closely than the earlier React
            POC.
          </p>
          <p>
            The clickable parent is an <code>a</code>, while the visible label
            lives in descendant spans:
            <code>.subtitle</code> and <code>.title</code>.
          </p>
          <div class="console" id="event-log">
Click either menu result to inspect the actual click target and parent element.
          </div>
        </section>
      </main>
    </div>

    <script>
      const log = document.getElementById("event-log");

      document.querySelectorAll(".result a").forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();

          const target = event.target;
          const current = event.currentTarget;
          const title = current.querySelector(".title")?.textContent?.trim();
          const subtitle = current
            .querySelector(".subtitle")
            ?.textContent?.trim();

          log.textContent =
            `event.target: <${target.tagName.toLowerCase()}>` +
            `\nevent.currentTarget: <${current.tagName.toLowerCase()}>` +
            `\nid: ${current.id}` +
            `\ntextContent: ${JSON.stringify(current.textContent.trim())}` +
            `\nsubtitle: ${JSON.stringify(subtitle)}` +
            `\ntitle: ${JSON.stringify(title)}`;
        });
      });
    </script>
  </body>
</html>
